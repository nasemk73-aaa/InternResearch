{
  "plansDirectory": "./work-tmp",
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run streamlit *)",
      "Bash(uv run mypy *)",
      "Bash(uv run ty *)",
      "Bash(uv run pre-commit *)",
      "Bash(uv sync *)",
      "Bash(uv pip *)",
      "Bash(yarn *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow view *)",
      "Bash(gh workflow list *)",
      "Bash(gh search *)",
      "Bash(git *)"
    ],
    "ask": [
      "Bash(*git push*)",
      "Bash(*git reset --hard*)",
      "Bash(*git clean*)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"$CLAUDE_PROJECT_DIR/scripts/log_agent_metrics.py\" subagent_invocation",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"$CLAUDE_PROJECT_DIR/scripts/log_agent_metrics.py\" skill_invocation",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre_bash_redirect.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post_edit_autofix.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop_check.sh",
            "timeout": 120,
            "statusMessage": "Running make check (fast)..."
          }
        ]
      }
    ]
  }
}
